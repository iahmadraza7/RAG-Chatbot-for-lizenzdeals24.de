<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/platform/trunk/src/Core/System/SystemConfig/Schema/config.xsd">
    <card>
        <title>Ginie Chatbot</title>
        <title lang="de-DE">Ginie Chatbot</title>

        <input-field type="bool">
            <name>enabled</name>
            <label>Enable chatbot</label>
            <label lang="de-DE">Chatbot aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="text">
            <name>backendUrl</name>
            <label>Backend chat URL</label>
            <label lang="de-DE">Backend Chat URL</label>
            <placeholder>https://your-api-host/chat</placeholder>
            <required>true</required>
        </input-field>

        <input-field type="text">
            <name>botName</name>
            <label>Bot name</label>
            <label lang="de-DE">Bot Name</label>
            <defaultValue>Ginie – Ihr Lizenzassistent</defaultValue>
        </input-field>

        <input-field type="text">
            <name>avatarUrl</name>
            <label>Avatar image URL</label>
            <label lang="de-DE">Avatar-Bild-URL</label>
            <defaultValue>https://lizenzdeals24.de/media/f8/33/c3/1782816369/Support%20Chatbot%20Icon%20Mensch.png?ts=1782816369</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>useAgentAvatar</name>
            <label>Use headset-agent avatar</label>
            <label lang="de-DE">Headset-Agent-Avatar nutzen</label>
            <defaultValue>false</defaultValue>
        </input-field>

        <input-field type="text">
            <name>agentAvatarUrl</name>
            <label>Headset-agent image URL</label>
            <label lang="de-DE">Headset-Agent-Bild-URL</label>
        </input-field>

        <input-field type="text">
            <name>greetingDE</name>
            <label>German greeting</label>
            <label lang="de-DE">Deutsche Begrüßung</label>
            <defaultValue>Wir sind online für Sie</defaultValue>
        </input-field>

        <input-field type="text">
            <name>greetingEN</name>
            <label>English greeting</label>
            <label lang="de-DE">Englische Begrüßung</label>
            <defaultValue>We are online for you.</defaultValue>
        </input-field>

        <input-field type="text">
            <name>supportEmail</name>
            <label>Support email</label>
            <label lang="de-DE">Support E-Mail</label>
            <defaultValue>support@lizenzdeals24.de</defaultValue>
        </input-field>

        <input-field type="text">
            <name>whatsappUrl</name>
            <label>WhatsApp link</label>
            <label lang="de-DE">WhatsApp Link</label>
            <placeholder>https://wa.me/49...</placeholder>
        </input-field>

        <input-field type="text">
            <name>telUrl</name>
            <label>Phone link</label>
            <label lang="de-DE">Telefon-Link</label>
            <defaultValue>tel:+4921732643330</defaultValue>
        </input-field>

        <input-field type="text">
            <name>contactUrl</name>
            <label>Contact form URL</label>
            <label lang="de-DE">Kontaktformular-URL</label>
            <defaultValue>/kontakt</defaultValue>
        </input-field>

        <input-field type="text">
            <name>primaryColor</name>
            <label>Primary color</label>
            <label lang="de-DE">Primärfarbe</label>
            <defaultValue>#1d4ed8</defaultValue>
        </input-field>

        <input-field type="text">
            <name>accentColor</name>
            <label>Button accent color</label>
            <label lang="de-DE">Button-Akzentfarbe</label>
            <defaultValue>#2563eb</defaultValue>
        </input-field>

        <input-field type="text">
            <name>primaryColorDark</name>
            <label>Header dark color</label>
            <label lang="de-DE">Dunkle Kopfzeilenfarbe</label>
            <defaultValue>#0f1e3d</defaultValue>
        </input-field>

        <input-field type="text">
            <name>defaultLang</name>
            <label>Default language</label>
            <label lang="de-DE">Standardsprache</label>
            <defaultValue>de</defaultValue>
            <helpText>Use de or en.</helpText>
            <helpText lang="de-DE">de oder en eintragen.</helpText>
        </input-field>

        <input-field type="int">
            <name>offsetBottom</name>
            <label>Launcher bottom offset</label>
            <label lang="de-DE">Launcher Abstand unten</label>
            <defaultValue>72</defaultValue>
        </input-field>

        <input-field type="int">
            <name>offsetRight</name>
            <label>Launcher right offset</label>
            <label lang="de-DE">Launcher Abstand rechts</label>
            <defaultValue>20</defaultValue>
        </input-field>
    </card>
</config>
